@{
    ViewData["Title"] = "Crear Cuenta";
    ViewData["HideNav"] = true;
}

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;">
    <div style="width:100%;max-width:440px;display:flex;flex-direction:column;gap:24px;">

        @* Logo *@
        <div style="text-align:center;">
            <div style="width:56px;height:56px;background:var(--accent);border-radius:14px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;">
                <span class="material-symbols-rounded" style="font-size:32px;color:#fff;">lock</span>
            </div>
            <div style="font-size:26px;font-weight:800;letter-spacing:0.5px;">
                <span style="color:var(--accent);">CER</span><span style="color:var(--text-primary);">BERUS</span>
            </div>
            <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Crear nueva cuenta</p>
        </div>

        <div class="card-sec">
            <div class="card-header-sec">
                <span class="material-symbols-rounded">person_add</span>
                Registro de Usuario
            </div>
            <div class="card-body-sec" style="display:flex;flex-direction:column;gap:20px;">

                @if (TempData["Error"] != null)
                {
                    <div class="alert-sec alert-error">
                        <span class="material-symbols-rounded">gpp_bad</span>
                        @TempData["Error"]
                    </div>
                }

                <div class="alert-sec alert-info">
                    <span class="material-symbols-rounded">info</span>
                    Las cuentas nuevas inician en plan <strong>Free</strong>.
                </div>

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <div style="display:flex;flex-direction:column;gap:16px;">

                        <div class="form-group-sec">
                            <label class="label-caps" for="nombreUsuario">Nombre de Usuario</label>
                            <input class="input-sec" type="text" id="nombreUsuario" name="nombreUsuario"
                                   placeholder="Ej: omar_g" autocomplete="username" required autofocus />
                        </div>

                        <div class="form-group-sec">
                            <label class="label-caps" for="email">Correo Electrónico</label>
                            <input class="input-sec" type="email" id="email" name="email"
                                   placeholder="tu@correo.com" autocomplete="email" />
                        </div>

                        <div class="form-group-sec">
                            <label class="label-caps" for="password">Contraseña</label>
                            <div class="input-group-sec">
                                <input class="input-sec" type="password" id="password" name="password"
                                       placeholder="Mínimo 8 caracteres" required />
                                <button type="button" class="input-icon-end" data-toggle-password="#password">
                                    <span class="material-symbols-rounded">visibility</span>
                                </button>
                            </div>
                        </div>

                        <div class="form-group-sec">
                            <label class="label-caps" for="passwordConfirm">Confirmar Contraseña</label>
                            <div class="input-group-sec">
                                <input class="input-sec" type="password" id="passwordConfirm" name="passwordConfirm"
                                       placeholder="Repite tu contraseña" required />
                                <button type="button" class="input-icon-end" data-toggle-password="#passwordConfirm">
                                    <span class="material-symbols-rounded">visibility</span>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn-sec btn-primary-sec btn-lg-sec btn-full">
                            <span class="material-symbols-rounded">person_add</span>
                            CREAR CUENTA
                        </button>
                    </div>
                </form>

                <div class="divider-sec"></div>

                <p style="text-align:center;font-size:13px;color:var(--text-muted);">
                    ¿Ya tienes cuenta?
                    <a asp-controller="Account" asp-action="Login">Iniciar sesión</a>
                </p>
            </div>
        </div>
    </div>
</div>
