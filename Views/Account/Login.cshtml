@{
    ViewData["Title"] = "Iniciar Sesión";
    ViewData["HideNav"] = true;
}

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;">
    <div style="width:100%;max-width:420px;display:flex;flex-direction:column;gap:24px;">

        @* Logo *@
        <div style="text-align:center;">
            <div style="width:56px;height:56px;background:var(--accent);border-radius:14px;display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;">
                <span class="material-symbols-rounded" style="font-size:32px;color:#fff;">lock</span>
            </div>
            <div style="font-size:26px;font-weight:800;letter-spacing:0.5px;">
                <span style="color:var(--accent);">CER</span><span style="color:var(--text-primary);">BERUS</span>
            </div>
            <p style="font-size:12px;color:var(--text-muted);margin-top:4px;">Bóveda Digital Multi-Cloud</p>
        </div>

        @* Card *@
        <div class="card-sec">
            <div class="card-header-sec">
                <span class="material-symbols-rounded">login</span>
                Iniciar Sesión
            </div>
            <div class="card-body-sec" style="display:flex;flex-direction:column;gap:20px;">

                @if (TempData["Error"] != null)
                {
                    <div class="alert-sec alert-error">
                        <span class="material-symbols-rounded">gpp_bad</span>
                        @TempData["Error"]
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" method="post"
                      asp-route-returnUrl="@ViewData["ReturnUrl"]">
                    @Html.AntiForgeryToken()

                    <div style="display:flex;flex-direction:column;gap:16px;">
                        <div class="form-group-sec">
                            <label class="label-caps" for="nombreUsuario">Usuario</label>
                            <input class="input-sec" type="text" id="nombreUsuario" name="nombreUsuario"
                                   placeholder="Tu nombre de usuario" autocomplete="username" required autofocus />
                        </div>

                        <div class="form-group-sec">
                            <label class="label-caps" for="password">Contraseña</label>
                            <div class="input-group-sec">
                                <input class="input-sec" type="password" id="password" name="password"
                                       placeholder="Tu contraseña" autocomplete="current-password" required />
                                <button type="button" class="input-icon-end" data-toggle-password="#password">
                                    <span class="material-symbols-rounded">visibility</span>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="btn-sec btn-primary-sec btn-lg-sec btn-full">
                            <span class="material-symbols-rounded">login</span>
                            ENTRAR
                        </button>
                    </div>
                </form>

                <div class="divider-sec"></div>

                <p style="text-align:center;font-size:13px;color:var(--text-muted);">
                    ¿No tienes cuenta?
                    <a asp-controller="Account" asp-action="Register">Crear una aquí</a>
                </p>
            </div>
        </div>

        <p style="text-align:center;font-size:11px;color:var(--text-muted);">
            Cerberus v1.0 · UABC 2026
        </p>
    </div>
</div>
