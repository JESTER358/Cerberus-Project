@model ProyectoInnovador.Models.ErrorViewModel
@{
    ViewData["Title"]  = "Error";
    ViewData["HideNav"] = true; // Oculta navbar en errores críticos
}

<div style="
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 24px;
    text-align: center;
    padding: 32px;
">
    <span class="badge-sec badge-error" style="font-size:12px;letter-spacing:2px;">ERROR 500</span>

    <div style="
        width: 96px; height: 96px;
        background: var(--bg-secondary);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid rgba(239,68,68,0.3);
    ">
        <span class="material-symbols-rounded" style="font-size:52px;color:var(--error);">bug_report</span>
    </div>

    <div style="display:flex;flex-direction:column;gap:8px;">
        <h1 style="font-size:32px;font-weight:800;color:var(--text-primary);">Algo salió mal</h1>
        <p style="font-size:15px;color:var(--text-muted);max-width:480px;line-height:1.6;">
            Ocurrió un error inesperado al procesar tu solicitud.
            Si el problema persiste, verifica que MinIO y Azurite estén corriendo.
        </p>
    </div>

    @if (Model?.ShowRequestId == true)
    {
        <div style="
            display: flex; align-items: center; gap: 8px;
            padding: 10px 16px;
            background: var(--bg-secondary);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
        ">
            <span style="font-size:12px;color:var(--text-muted);">Request ID:</span>
            <code style="font-size:12px;color:var(--text-secondary);">@Model.RequestId</code>
        </div>
    }

    <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;">
        <a class="btn-sec btn-primary-sec" asp-controller="Dashboard" asp-action="Index">
            <span class="material-symbols-rounded">home</span>
            Ir al Panel
        </a>
        <a class="btn-sec btn-ghost-sec" href="javascript:history.back()">
            <span class="material-symbols-rounded">arrow_back</span>
            Volver atrás
        </a>
    </div>
</div>
