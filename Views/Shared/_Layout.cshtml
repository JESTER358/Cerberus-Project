<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Cerberus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/encripta.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="app-shell">

    @* Navbar solo se muestra fuera del login *@
    @if (ViewData["HideNav"] == null)
    {
        <nav class="navbar-sec">
            <a class="navbar-brand-sec" asp-controller="Dashboard" asp-action="Index">
                <div class="brand-icon">
                    <span class="material-symbols-rounded">lock</span>
                </div>
                <span class="brand-name">
                    <span class="sec">CER</span><span class="core">BERUS</span>
                </span>
                <span class="brand-version">v1.0</span>
            </a>

            <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
                <span class="material-symbols-rounded">menu</span>
            </button>

            <div class="navbar-spacer"></div>

            <div class="navbar-links" id="navbarLinks">
                <a class="nav-link-sec @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <span class="material-symbols-rounded">dashboard</span>
                    Panel
                </a>
                <a class="nav-link-sec @(ViewData["ActivePage"]?.ToString() == "Logs" ? "active" : "")"
                   asp-controller="Log" asp-action="Index">
                    <span class="material-symbols-rounded">history</span>
                    Historial
                </a>
                <a class="nav-link-sec @(ViewData["ActivePage"]?.ToString() == "Plans" ? "active" : "")"
                   asp-controller="Plans" asp-action="Index">
                    <span class="material-symbols-rounded">workspace_premium</span>
                    Planes
                </a>
                <a class="nav-link-sec @(ViewData["ActivePage"]?.ToString() == "Settings" ? "active" : "")"
                   asp-controller="Settings" asp-action="Index">
                    <span class="material-symbols-rounded">settings</span>
                    Ajustes
                </a>
                @if (Context.Session.GetString("UsuarioAdmin") == "true")
                {
                    <a class="nav-link-sec @(ViewData["ActivePage"]?.ToString() == "Admin" ? "active" : "")"
                       asp-controller="Admin" asp-action="Index">
                        <span class="material-symbols-rounded">admin_panel_settings</span>
                        Admin
                    </a>
                }
                <div class="nav-divider"></div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;padding:0 8px;line-height:1.3;">
                    <span style="font-size:13px;font-weight:700;color:var(--text-primary);">
                        @(Context.Session.GetString("UsuarioNombre") ?? "")
                    </span>
                    <span style="font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--accent);">
                        @(Context.Session.GetString("UsuarioPlan") ?? "")
                    </span>
                </div>
                <a class="nav-link-sec danger" href="#" id="logoutTrigger">
                    <span class="material-symbols-rounded">logout</span>
                    Cerrar Sesión
                </a>
            </div>
        </nav>

        @* Modal Logout *@
        <div class="modal-backdrop-sec" id="logoutModal">
            <div class="modal-sec" style="max-width:400px">
                <div class="modal-header-sec">
                    <div class="modal-icon-wrap danger">
                        <span class="material-symbols-rounded">logout</span>
                    </div>
                    <span class="modal-title-sec">Cerrar Sesión</span>
                    <button class="modal-close" id="logoutCancel">
                        <span class="material-symbols-rounded">close</span>
                    </button>
                </div>
                <div class="modal-body-sec">
                    <p style="color:var(--text-primary);font-size:15px;">¿Estás seguro que deseas terminar tu sesión segura?</p>
                    <div class="alert-sec alert-info">
                        <span class="material-symbols-rounded">info</span>
                        Tu sesión y los datos temporales en memoria serán eliminados.
                    </div>
                </div>
                <div class="modal-footer-sec">
                    <button class="btn-sec btn-ghost-sec" id="logoutCancelBtn">Cancelar</button>
                    <a class="btn-sec btn-danger-sec" asp-controller="Account" asp-action="Logout">
                        <span class="material-symbols-rounded">logout</span>
                        Cerrar Sesión
                    </a>
                </div>
            </div>
        </div>
    }

    <main class="app-main">
        @* Mensajes flash (TempData) *@
        @if (TempData["Success"] != null)
        {
            <div class="alert-sec alert-success" style="margin-bottom:20px">
                <span class="material-symbols-rounded">check_circle</span>
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-sec alert-error" style="margin-bottom:20px">
                <span class="material-symbols-rounded">gpp_bad</span>
                @TempData["Error"]
            </div>
        }

        @RenderBody()
    </main>

</div>

<script>
    // Modal logout
    const logoutModal   = document.getElementById('logoutModal');
    const logoutTrigger = document.getElementById('logoutTrigger');
    const logoutCancel  = document.getElementById('logoutCancel');
    const logoutCancelBtn = document.getElementById('logoutCancelBtn');

    function openLogout(e)  { e?.preventDefault(); logoutModal?.classList.add('open'); }
    function closeLogout()  { logoutModal?.classList.remove('open'); }

    logoutTrigger?.addEventListener('click', openLogout);
    logoutCancel?.addEventListener('click', closeLogout);
    logoutCancelBtn?.addEventListener('click', closeLogout);
    logoutModal?.addEventListener('click', e => { if (e.target === logoutModal) closeLogout(); });

    // Mobile nav toggle
    const navToggle = document.getElementById('navToggle');
    const navbarLinks = document.getElementById('navbarLinks');
    navToggle?.addEventListener('click', () => {
        navbarLinks?.classList.toggle('open');
    });

    // Cerrar menú al seleccionar opción
    navbarLinks?.querySelectorAll('a.nav-link-sec').forEach(link => {
        link.addEventListener('click', () => navbarLinks.classList.remove('open'));
    });

    // Toggle contraseña
    document.querySelectorAll('[data-toggle-password]').forEach(btn => {
        btn.addEventListener('click', () => {
            const input = document.querySelector(btn.dataset.togglePassword);
            if (!input) return;
            const isPass = input.type === 'password';
            input.type = isPass ? 'text' : 'password';
            btn.querySelector('.material-symbols-rounded').textContent = isPass ? 'visibility_off' : 'visibility';
        });
    });

    // Auto-dismiss alerts
    document.querySelectorAll('.alert-sec').forEach(el => {
        setTimeout(() => { el.style.transition = 'opacity 0.5s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 500); }, 5000);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
